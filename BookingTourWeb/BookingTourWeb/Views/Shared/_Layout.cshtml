<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookingTourWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookingTourWeb.styles.css" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 text-decoration-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
                        <path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
                        <path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
                    </svg>
                    <span class="text-xl font-bold text-gray-900">OceanWave</span>
                </a>

                <div class="hidden md:flex items-center gap-8">
                    <a asp-controller="Home" asp-action="Index" class="text-gray-600 hover:text-blue-600 transition-colors font-medium text-decoration-none">Home</a>
                    <a asp-controller="Tour" asp-action="Index" class="text-gray-600 hover:text-blue-600 transition-colors font-medium text-decoration-none">Tour List</a>
                    <a asp-controller="Home" asp-action="About" class="text-gray-600 hover:text-blue-600 transition-colors font-medium text-decoration-none">About Us</a>
                    <a asp-controller="Home" asp-action="Contact" class="text-gray-600 hover:text-blue-600 transition-colors font-medium text-decoration-none">Contact Us</a>
                </div>

                <div class="hidden md:flex items-center gap-3">
                    <a asp-controller="Account" asp-action="Login" class="text-gray-900 hover:text-blue-600 font-medium px-4 py-2 text-decoration-none">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors font-medium text-decoration-none">Register</a>
                </div>

                <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-900 focus:outline-none" aria-label="Toggle menu">
                    <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div id="mobile-nav" class="hidden md:hidden py-4 border-t border-gray-200 bg-white">
                <div class="flex flex-col gap-4 px-2">
                    <a asp-controller="Home" asp-action="Index" class="text-gray-600 hover:text-blue-600 transition-colors font-medium py-2 text-decoration-none">Home</a>
                    <a asp-controller="Tour" asp-action="Index" class="text-gray-600 hover:text-blue-600 transition-colors font-medium py-2 text-decoration-none">Tour List</a>
                    <a asp-controller="Home" asp-action="About" class="text-gray-600 hover:text-blue-600 transition-colors font-medium py-2 text-decoration-none">About Us</a>
                    <a asp-controller="Home" asp-action="Contact" class="text-gray-600 hover:text-blue-600 transition-colors font-medium py-2 text-decoration-none">Contact Us</a>

                    <div class="flex flex-col gap-2 pt-4 border-t border-gray-200">
                        <a asp-controller="Account" asp-action="Login" class="text-gray-900 font-medium py-2 text-decoration-none">Login</a>
                        <a asp-controller="Account" asp-action="Register" class="bg-blue-600 text-white text-center px-4 py-2 rounded-md hover:bg-blue-700 font-medium text-decoration-none">Register</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <script>
        const btn = document.getElementById('mobile-menu-btn');
        const nav = document.getElementById('mobile-nav');
        const iconMenu = document.getElementById('icon-menu');
        const iconClose = document.getElementById('icon-close');

        btn.addEventListener('click', () => {
            nav.classList.toggle('hidden');
            iconMenu.classList.toggle('hidden');
            iconClose.classList.toggle('hidden');
        });
    </script>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="bg-gray-900 text-white mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">

                <div class="lg:col-span-1">
                    <a asp-controller="Tour" asp-action="Index" class="flex items-center gap-2 mb-4 text-decoration-none">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
                            <path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
                            <path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
                        </svg>
                        <span class="text-xl font-bold text-white">OceanWave</span>
                    TourList
                    </a>
                    <p class="text-gray-400 mb-6 text-sm">
                        Cánh cửa đưa bạn đến với những cuộc phiêu lưu trên biển và trải nghiệm lặn ngắm san hô khó quên.
                    </p>
                    <div class="flex items-center gap-4">
                        <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-colors">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
                        </a>
                        <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-colors">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" /></svg>
                        </a>
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-semibold mb-4 text-white">Liên Kết Nhanh</h3>
                    <ul class="space-y-3 list-none pl-0">
                        <li><a asp-controller="Home" asp-action="Index" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Trang Chủ</a></li>
                        <li><a asp-controller="Tour" asp-action="Index" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Danh Sách Tour</a></li>
                        <li><a asp-controller="Home" asp-action="About" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Về Chúng Tôi</a></li>
                        <li><a asp-controller="Home" asp-action="Contact" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Liên Hệ</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-lg font-semibold mb-4 text-white">Hỗ Trợ</h3>
                    <ul class="space-y-3 list-none pl-0">
                        <li><a href="#" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Câu hỏi thường gặp (FAQ)</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Điều khoản & Điều kiện</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Chính sách bảo mật</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">Chính sách đặt hủy tour</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-lg font-semibold mb-4 text-white">Thông Tin Liên Hệ</h3>
                    <ul class="space-y-3 list-none pl-0">
                        <li class="flex items-start gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <span class="text-gray-400">123 Đường Trần Phú, Lộc Thọ, Nha Trang, Việt Nam</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                            <a href="tel:+84777439917" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">0777.439.917</a>
                        </li>
                        <li class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <a href="mailto:contact@oceanwave.vn" class="text-gray-400 hover:text-blue-500 transition-colors text-decoration-none">contact@oceanwave.vn</a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="mt-12 pt-8 border-t border-gray-800">
                <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                    <p class="text-gray-500 text-sm mb-0">
                        &copy; @DateTime.Now.Year OceanWave Tours. Bản quyền thuộc về sinh viên làm đồ án.
                    </p>
                    <p class="text-gray-500 text-sm mb-0">
                        Thiết kế với ❤️ dành cho người yêu biển
                    </p>
                </div>
            </div>
        </div>
    </footer>

    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
