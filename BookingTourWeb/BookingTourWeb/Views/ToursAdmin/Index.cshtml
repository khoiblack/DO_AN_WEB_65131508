@model IEnumerable<BookingTourWeb.Models.Tour>

@{
    ViewData["Title"] = "Quản lý Danh sách Tour";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Sử dụng bộ khung Admin xịn sò của bạn
}

<div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
    <div>
        <h2 class="text-2xl font-bold text-gray-900">Danh sách Tour Du lịch</h2>
        <p class="text-gray-500 text-sm mt-1">Quản lý, thêm mới và cập nhật các gói tour của hệ thống</p>
    </div>
    <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-5 rounded-xl shadow-lg shadow-blue-200 transition-all flex items-center gap-2 text-decoration-none transform hover:-translate-y-0.5">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Thêm Tour Mới
    </a>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider">
                    <th class="px-6 py-4 font-bold">Hình ảnh & Tên Tour</th>
                    <th class="px-6 py-4 font-bold">Giá tiền</th>
                    <th class="px-6 py-4 font-bold text-center">Trạng thái</th>
                    <th class="px-6 py-4 font-bold text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                            <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" /></svg>
                            <p class="text-base font-medium">Chưa có Tour nào trong hệ thống</p>
                            <p class="text-sm mt-1">Bấm nút "Thêm Tour Mới" để bắt đầu.</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="h-14 w-20 rounded-lg bg-gray-200 overflow-hidden flex-shrink-0">
                                        <img src="~/images/@item.Image" alt="Tour Image" class="h-full w-full object-cover" onerror="this.src='https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=200&q=80'" />
                                    </div>
                                    <div>
                                        <div class="font-bold text-gray-900 text-sm">@item.Name</div>
                                        <div class="text-xs text-gray-500 mt-0.5 max-w-[200px] truncate">@item.Location</div>
                                    </div>
                                </div>
                            </td>

                            <td class="px-6 py-4">
                                <span class="font-bold text-blue-600">@item.Price.ToString("N0") VNĐ</span>
                            </td>

                            <td class="px-6 py-4 text-center">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-green-50 text-green-600 border border-green-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                    Đang mở bán
                                </span>
                            </td>

                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Sửa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="p-2 text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" title="Chi tiết">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Xóa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>