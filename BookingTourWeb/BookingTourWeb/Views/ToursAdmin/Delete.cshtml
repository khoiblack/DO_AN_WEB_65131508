@model BookingTourWeb.Models.Tour
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Xóa Tour";
}

<div class="max-w-2xl mx-auto mt-10">
    <div class="bg-white rounded-3xl shadow-sm border border-red-100 overflow-hidden">

        <div class="bg-red-50 px-8 py-6 border-b border-red-100 flex items-center gap-4">
            <div class="bg-red-100 text-red-600 p-3 rounded-full">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-red-700">Xóa Tour Này?</h1>
                <p class="text-red-500 mt-1">Hành động này không thể hoàn tác. Dữ liệu và hình ảnh sẽ bị xóa vĩnh viễn.</p>
            </div>
        </div>

        <div class="p-8">
            <div class="flex items-center gap-6 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                <img src="~/images/@Model.Image" alt="Tour Image" class="w-32 h-24 object-cover rounded-xl shadow-sm" onerror="this.src='/images/default-tour.jpg'" />
                <div>
                    <h3 class="text-xl font-bold text-gray-900">@Model.Name</h3>
                    <p class="text-gray-500 mb-2">@Model.Location</p>
                    <span class="font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full text-sm">@Model.Price.ToString("N0") VNĐ</span>
                </div>
            </div>

            <form asp-action="Delete" class="mt-8 flex gap-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-red-200">
                    Vâng, Xóa Ngay
                </button>
                <a asp-action="Index" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-8 rounded-xl transition-all">
                    Quay lại an toàn
                </a>
            </form>
        </div>

    </div>
</div>