@model BookingTourWeb.Models.Tour
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết Tour";
}

<div class="max-w-5xl mx-auto mt-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Chi tiết Tour Du Lịch</h1>
            <p class="text-gray-500 mt-1">Xem thông tin tổng quan của gói tour này</p>
        </div>
        <a asp-action="Index" class="flex items-center gap-2 text-gray-600 hover:text-blue-600 font-medium transition-colors bg-white px-5 py-2.5 rounded-xl shadow-sm border border-gray-200 hover:border-blue-200 text-decoration-none">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Quay lại danh sách
        </a>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-0">

            <div class="lg:col-span-2 h-64 lg:h-auto relative bg-gray-100">
                <img src="~/images/@Model.Image" alt="@Model.Name" class="w-full h-full object-cover" onerror="this.src='/images/default-tour.jpg'" />
                <div class="absolute top-4 left-4">
                    <span class="px-3 py-1.5 bg-white/90 backdrop-blur-md text-green-600 text-xs font-bold rounded-lg shadow-sm uppercase tracking-wider flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                        Đang mở bán
                    </span>
                </div>
            </div>

            <div class="lg:col-span-3 p-8 md:p-10 flex flex-col">
                <div class="mb-6">
                    <div class="flex items-center gap-2 text-gray-500 text-sm font-bold mb-3 uppercase tracking-wider">
                        <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        @Model.Location
                    </div>
                    <h2 class="text-3xl font-extrabold text-gray-900 leading-tight mb-4">@Model.Name</h2>
                    <div class="text-3xl font-black text-blue-600">@Model.Price.ToString("N0") <span class="text-lg text-gray-500 font-medium">VNĐ</span></div>
                </div>

                <hr class="border-gray-100 mb-6" />

                <div class="grid grid-cols-2 gap-6 mb-10 flex-grow">
                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <p class="text-gray-400 text-xs uppercase tracking-wider font-bold mb-1">Thời gian</p>
                        <p class="text-gray-900 font-bold flex items-center gap-2">
                            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            @Model.Duration
                        </p>
                    </div>

                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <p class="text-gray-400 text-xs uppercase tracking-wider font-bold mb-1">Số lượng khách</p>
                        <p class="text-gray-900 font-bold flex items-center gap-2">
                            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            @Model.GroupSize
                        </p>
                    </div>

                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <p class="text-gray-400 text-xs uppercase tracking-wider font-bold mb-1">Đánh giá sao</p>
                        <p class="text-gray-900 font-bold flex items-center gap-2">
                            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                            @Model.Rating / 5.0
                        </p>
                    </div>

                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100">
                        <p class="text-gray-400 text-xs uppercase tracking-wider font-bold mb-1">Lượt Review</p>
                        <p class="text-gray-900 font-bold flex items-center gap-2">
                            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                            @Model.Reviews đánh giá
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-4 mt-auto">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-xl text-center transition-all shadow-lg shadow-blue-200 text-decoration-none">
                        Sửa Tour này
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="flex-1 bg-red-50 hover:bg-red-100 text-red-600 font-bold py-3.5 px-4 rounded-xl text-center transition-all text-decoration-none">
                        Xóa Tour
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>