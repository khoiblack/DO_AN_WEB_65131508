@model BookingTourWeb.Models.Tour
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sửa thông tin Tour";
}

<div class="max-w-4xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">✏️ Cập nhật Tour Du Lịch</h1>
        <p class="text-gray-500">Chỉnh sửa thông tin gói tour: <span class="font-bold text-blue-600">@Model.Name</span></p>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data" class="space-y-6">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Image" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Tên Tour</label>
                <input asp-for="Name" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-blue-600 outline-none" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Địa điểm</label>
                <input asp-for="Location" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-blue-600 outline-none" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Giá tiền (VNĐ)</label>
                <input asp-for="Price" type="number" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-blue-600 outline-none" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Thời gian</label>
                <input asp-for="Duration" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-blue-600 outline-none" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Số lượng khách</label>
                <input asp-for="GroupSize" class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 focus:ring-2 focus:ring-blue-600 outline-none" required />
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Hình ảnh hiện tại (Tải ảnh mới để thay thế)</label>
                <div class="mt-1 p-4 border-2 border-gray-200 border-dashed rounded-xl bg-gray-50">

                    <div class="flex flex-col sm:flex-row items-center gap-6">
                        <img id="image-preview" src="~/images/@Model.Image" alt="Current Image" class="h-32 w-48 object-cover rounded-lg shadow-sm border border-gray-200" onerror="this.src='/images/default-tour.jpg'" />

                        <div>
                            <label class="relative cursor-pointer bg-white rounded-lg font-medium text-blue-600 hover:text-blue-500 px-4 py-2 border shadow-sm transition-all">
                                <span>Chọn ảnh mới (nếu muốn đổi)</span>
                                <input asp-for="ImageUpload" type="file" class="sr-only" accept="image/*" onchange="previewImage(event)">
                            </label>
                            <p class="text-xs text-gray-500 mt-2">Định dạng: PNG, JPG (Giữ nguyên nếu không up ảnh mới)</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="flex items-center gap-4 pt-6 border-t mt-6">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl font-bold transition-colors shadow-lg shadow-blue-200">
                Lưu Thay Đổi
            </button>
            <a asp-action="Index" class="text-gray-500 hover:text-gray-900 font-medium px-4 py-2 hover:bg-gray-100 rounded-xl transition-colors">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>
@section Scripts {
    <script>
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function () {
                // Tìm đến thẻ img có id là image-preview và đổi src thành ảnh mới
                var previewImage = document.getElementById('image-preview');
                previewImage.src = reader.result;
            }

            // Nếu có chọn file thì mới bắt đầu đọc
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}