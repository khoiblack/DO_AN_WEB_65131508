@model BookingTourWeb.Models.Tour

@{
    // Ép nó phải dùng giao diện của Admin, không dùng giao diện khách hàng nữa!
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Tour Mới";
}

<div class="max-w-4xl mx-auto bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">✨ Thêm Tour Du Lịch Mới</h1>
        <p class="text-gray-500">Điền thông tin chi tiết và tải ảnh lên cho gói tour mới.</p>
    </div>

    <form asp-action="Create" enctype="multipart/form-data" class="space-y-6">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Tên Tour</label>
                <input asp-for="Name" class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" placeholder="VD: Khám phá Vịnh Hạ Long..." required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Địa điểm (Điểm đến)</label>
                <input asp-for="Location" class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" placeholder="VD: Nha Trang" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Giá tiền ($)</label>
                <input asp-for="Price" type="number" class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Thời gian (Duration)</label>
                <input asp-for="Duration" class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" placeholder="VD: 3 ngày 2 đêm" required />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Số lượng khách tối đa</label>
                <input asp-for="GroupSize" class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" placeholder="VD: 15 người" required />
            </div>

            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Tải ảnh lên</label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-blue-500 transition-colors bg-gray-50">

                    <div id="upload-prompt" class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="flex text-sm text-gray-600 justify-center mt-4">
                            <label class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 px-3 py-2 border shadow-sm">
                                <span>Bấm vào đây để chọn tệp</span>
                                <input asp-for="ImageUpload" id="file-upload" type="file" class="sr-only" accept="image/*" required onchange="previewImage(event)">
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-2">Định dạng hỗ trợ: PNG, JPG, JPEG</p>
                    </div>

                    <div id="image-preview-container" class="hidden text-center">
                        <img id="image-preview" src="#" alt="Ảnh xem trước" class="mx-auto h-48 object-cover rounded-lg shadow-sm border border-gray-200 mb-3" />
                        <button type="button" onclick="removeImage()" class="text-sm text-red-600 font-medium hover:text-red-800">
                            Xóa ảnh và chọn lại
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <div class="flex items-center gap-4 pt-6 border-t mt-6">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-xl font-bold transition-colors shadow-lg shadow-blue-200">
                Lưu Tour Này
            </button>
            <a asp-action="Index" class="text-gray-500 hover:text-gray-900 font-medium px-4 py-2 hover:bg-gray-100 rounded-xl transition-colors">
                Trở về danh sách
            </a>
        </div>
    </form>
</div>
@section Scripts {
    <script>
        // Hàm hiển thị ảnh xem trước
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function () {
                // Ẩn khung báo tải ảnh
                document.getElementById('upload-prompt').classList.add('hidden');

                // Hiện khung chứa ảnh và gán link ảnh vào
                var previewContainer = document.getElementById('image-preview-container');
                var previewImage = document.getElementById('image-preview');
                previewImage.src = reader.result;
                previewContainer.classList.remove('hidden');
            }
            // Đọc file vừa chọn
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        // Hàm xóa ảnh (hủy chọn)
        function removeImage() {
            // Xóa file trong input
            document.getElementById('file-upload').value = "";

            // Ẩn ảnh xem trước, hiện lại khung chọn file
            document.getElementById('image-preview-container').classList.add('hidden');
            document.getElementById('upload-prompt').classList.remove('hidden');
        }
    </script>
}