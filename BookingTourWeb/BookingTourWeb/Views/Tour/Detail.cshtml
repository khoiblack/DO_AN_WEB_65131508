@model BookingTourWeb.Models.Tour

@{
    ViewData["Title"] = Model.Name;
}

<div class="min-h-screen bg-white">
    <main class="pt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

            <div class="mb-6">
                <nav class="text-sm text-gray-500 mb-4">
                    <a asp-controller="Home" asp-action="Index" class="hover:text-blue-600">Trang chủ</a>
                    <span class="mx-2">/</span>
                    <a asp-controller="Tour" asp-action="Index" class="hover:text-blue-600">Tours</a>
                    <span class="mx-2">/</span>
                    <span class="text-gray-900 font-medium">@Model.Name</span>
                </nav>

                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
                    <div>
                        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-3">
                            @Model.Name
                        </h1>

                        <div class="flex flex-wrap items-center gap-4 text-gray-500">
                            <div class="flex items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                <span>@Model.Location</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="flex text-yellow-400">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 @(i < Math.Floor(Model.Rating) ? "fill-current" : "text-gray-300")" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                                    }
                                </div>
                                <span class="font-semibold text-gray-900">@Model.Rating</span>
                                <span>(@Model.Reviews reviews)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-8 rounded-3xl overflow-hidden shadow-lg h-[400px]">
                @{
                    // Thuật toán thông minh xử lý đường dẫn ảnh (Giống hệt trang Index)
                    string detailImageSrc = string.IsNullOrEmpty(Model.Image) ? "/images/default-tour.jpg" : Model.Image;

                    if (!detailImageSrc.StartsWith("/") && !detailImageSrc.StartsWith("http"))
                    {
                        detailImageSrc = "/images/" + detailImageSrc;
                    }
                }
                <img src="@detailImageSrc" alt="@Model.Name" class="w-full h-full object-cover" onerror="this.src='/images/default-tour.jpg'" />
            </div>

            <div class="grid lg:grid-cols-[1fr_380px] gap-8">

                <div class="space-y-8">
                    <div class="flex flex-wrap gap-6 p-6 bg-gray-50 rounded-2xl">
                        <div class="flex items-center gap-3">
                            <div class="h-12 w-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 uppercase tracking-wider">Thời gian</p>
                                <p class="font-bold text-gray-900">@Model.Duration</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="h-12 w-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 uppercase tracking-wider">Số lượng</p>
                                <p class="font-bold text-gray-900">@Model.GroupSize</p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-4">Về chuyến đi này</h2>
                        <div class="text-gray-600 leading-relaxed space-y-4">
                            <p>Khám phá @Model.Location với những trải nghiệm tuyệt vời nhất. Chúng tôi cam kết mang đến một hành trình an toàn, thú vị và đầy kỷ niệm.</p>
                            <p>Gói tour bao gồm đầy đủ trang thiết bị, hướng dẫn viên chuyên nghiệp và bảo hiểm du lịch trọn gói.</p>
                        </div>
                    </div>
                </div>

                <div class="lg:relative">
                    <div class="lg:sticky lg:top-24 bg-white border border-gray-100 shadow-2xl rounded-3xl p-6">
                        <div class="mb-6">
                            <p class="text-gray-500 mb-1">Giá chỉ từ</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-3xl font-bold text-blue-600">$@Model.Price</span>
                                <span class="text-gray-500">/ người</span>
                            </div>
                        </div>

                        <form asp-controller="Booking" asp-action="Create" method="POST" class="space-y-4">
                            <input type="hidden" name="TourId" value="@Model.Id" />

                            <div>
                                <label class="block text-sm font-medium mb-1">Ngày đi</label>
                                <input type="date" name="DepartureDate" required class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" />
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium mb-1">Họ tên</label>
                                    <input type="text" name="CustomerName" required placeholder="Tên của bạn" class="w-full px-4 py-2 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium mb-1">SĐT</label>
                                    <input type="tel" name="PhoneNumber" required placeholder="09xxx" class="w-full px-4 py-2 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" />
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium mb-1">Số lượng khách</label>
                                <input type="number" name="NumberOfGuests" min="1" value="1" class="w-full px-4 py-3 rounded-xl bg-gray-50 border-none focus:ring-2 focus:ring-blue-600 outline-none" />
                            </div>

                            <button type="submit" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg transition-transform active:scale-95">
                                Đặt Tour Ngay
                            </button>
                        </form>

                        <p class="text-center text-xs text-gray-400 mt-4 italic">Chúng tôi sẽ gọi lại để xác nhận đơn hàng của bạn.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>