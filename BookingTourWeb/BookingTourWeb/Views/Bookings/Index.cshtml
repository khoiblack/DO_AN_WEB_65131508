@model IEnumerable<BookingTourWeb.Models.Booking>

@{
    Layout = "_AdminLayout"; // Nhớ gõ đúng tên file layout admin
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="pt-28 pb-20 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Bookings</h1>
            <p class="text-gray-500">Manage and monitor all customer tour reservations.</p>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white overflow-hidden shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700">ID</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700">Customer Name</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700">Tour Name</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700">Date</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700 text-right">Guests</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700 text-right">Total Price</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700">Status</th>
                        <th class="px-6 py-4 font-semibold text-sm text-gray-700 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var booking in Model)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4 font-medium text-sm text-gray-900">#@booking.Id</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@booking.CustomerName</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@(booking.Tour?.Name ?? "N/A")</td>
                            <td class="px-6 py-4 text-sm text-gray-600">
                                @booking.DepartureDate.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-6 py-4 text-right text-sm text-gray-600">@booking.NumberOfGuests</td>
                            <td class="px-6 py-4 text-right text-sm font-medium text-blue-600">
                                $@booking.TotalPrice.ToString("N2")
                            </td>
                            <td class="px-6 py-4">
                                @{
                                    // Logic phân loại Badge giống hệt v0
                                    var badgeClass = "bg-gray-100 text-gray-700"; // Mặc định là Pending
                                    var statusText = "Pending";

                                    // Chỗ này bạn có thể thêm logic cột Status vào Database sau
                                    // Hiện tại mình để mặc định theo thiết kế của bạn
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        Confirmed
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-center gap-2">
                                    <a asp-action="Details" asp-route-id="@booking.Id" class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="View details">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" /></svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@booking.Id" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete booking">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line x1="10" y1="11" x2="10" y2="17" /><line x1="14" y1="11" x2="14" y2="17" /></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="flex h-32 items-center justify-center text-center text-gray-400">
                    <p>No bookings found</p>
                </div>
            }
        </div>
    </div>
</div>