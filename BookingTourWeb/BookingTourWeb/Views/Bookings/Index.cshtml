@model IEnumerable<BookingTourWeb.Models.Booking>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
    <div>
        <h2 class="text-2xl font-bold text-gray-900">Quản lý Đơn đặt Tour</h2>
        <p class="text-gray-500 text-sm mt-1">Theo dõi, gọi điện xác nhận và quản lý trạng thái các đơn hàng.</p>
    </div>
    <div class="flex gap-3">
        <div class="bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-100 flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-amber-400 animate-pulse"></div>
            <span class="text-sm font-medium text-gray-600">Đang chờ: <b class="text-gray-900">@Model.Count(b => b.Status == "Chờ xác nhận")</b></span>
        </div>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider">
                    <th class="px-6 py-4 font-bold">Mã Đơn</th>
                    <th class="px-6 py-4 font-bold">Khách hàng</th>
                    <th class="px-6 py-4 font-bold">Tour đăng ký & Ngày đi</th>
                    <th class="px-6 py-4 font-bold text-center">Số lượng</th>
                    <th class="px-6 py-4 font-bold text-right">Tổng tiền</th>
                    <th class="px-6 py-4 font-bold text-center">Trạng thái</th>
                    <th class="px-6 py-4 font-bold text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-16 text-center text-gray-400">
                            <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            <p class="text-base font-medium text-gray-500">Chưa có đơn đặt tour nào</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var booking in Model)
                    {
                        <tr class="hover:bg-blue-50/50 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-sm font-bold text-gray-900">#@booking.Id</span>
                            </td>

                            <td class="px-6 py-4">
                                <div class="font-bold text-gray-900 text-sm">@booking.CustomerName</div>
                                <div class="text-xs text-blue-600 font-medium mt-0.5 flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                                    @booking.PhoneNumber
                                </div>
                            </td>

                            <td class="px-6 py-4">
                                <div class="text-sm font-medium text-gray-800 line-clamp-1 max-w-[250px]" title="@(booking.Tour?.Name ?? "Tour đã bị xóa")">
                                    @(booking.Tour?.Name ?? "Tour đã bị xóa")
                                </div>
                                <div class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                                    <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                    Đi: @booking.DepartureDate.ToString("dd/MM/yyyy")
                                </div>
                            </td>

                            <td class="px-6 py-4 text-center">
                                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 text-sm font-bold text-gray-700">
                                    @booking.NumberOfGuests
                                </span>
                            </td>

                            <td class="px-6 py-4 text-right">
                                <span class="font-bold text-blue-600">@booking.TotalPrice.ToString("N0") VNĐ</span>
                            </td>

                            <td class="px-6 py-4 text-center">
                                @{
                                    string badgeBg = "bg-gray-100 border-gray-200 text-gray-700";
                                    string dotColor = "bg-gray-500";

                                    if (booking.Status == "Chờ xác nhận")
                                    {
                                        badgeBg = "bg-amber-50 border-amber-200 text-amber-700";
                                        dotColor = "bg-amber-500";
                                    }
                                    else if (booking.Status == "Đã thanh toán" || booking.Status == "Hoàn tất")
                                    {
                                        badgeBg = "bg-emerald-50 border-emerald-200 text-emerald-700";
                                        dotColor = "bg-emerald-500";
                                    }
                                    else if (booking.Status == "Đã hủy")
                                    {
                                        badgeBg = "bg-red-50 border-red-200 text-red-700";
                                        dotColor = "bg-red-500";
                                    }
                                }
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold border @badgeBg">
                                    <span class="w-1.5 h-1.5 rounded-full @dotColor"></span>
                                    @booking.Status
                                </span>
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2 opacity-50 group-hover:opacity-100 transition-opacity">
                                    <a asp-action="Details" asp-route-id="@booking.Id" class="p-2 text-blue-600 hover:bg-blue-100 rounded-lg transition-colors" title="Cập nhật đơn hàng">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@booking.Id" class="p-2 text-red-600 hover:bg-red-100 rounded-lg transition-colors" title="Xóa đơn hàng">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>