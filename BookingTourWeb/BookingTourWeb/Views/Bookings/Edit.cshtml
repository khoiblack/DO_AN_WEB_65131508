@model BookingTourWeb.Models.Booking

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cập nhật trạng thái Đơn hàng";
}

<div class="max-w-3xl mx-auto mt-10">
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">

        <div class="px-8 py-6 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Cập nhật Đơn hàng</h1>
                <p class="text-gray-500 mt-1">Mã đơn: <span class="font-bold text-blue-600">#@Model.Id</span></p>
            </div>
            <a asp-action="Index" class="text-gray-500 hover:text-gray-900 font-medium bg-white px-4 py-2 border shadow-sm rounded-xl transition-colors text-decoration-none">
                Quay lại
            </a>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-2 gap-6 bg-blue-50/50 p-6 rounded-2xl border border-blue-100 mb-8">
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Khách hàng</p>
                    <p class="font-bold text-gray-900">@Model.CustomerName</p>
                    <p class="text-sm text-blue-600 font-medium">@Model.PhoneNumber</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Tổng tiền cần thu</p>
                    <p class="text-2xl font-black text-blue-600">@Model.TotalPrice.ToString("N0") VNĐ</p>
                </div>
            </div>

            <form asp-action="Edit" class="space-y-6">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="TourId" />
                <input type="hidden" asp-for="CustomerName" />
                <input type="hidden" asp-for="PhoneNumber" />
                <input type="hidden" asp-for="DepartureDate" />
                <input type="hidden" asp-for="NumberOfGuests" />
                <input type="hidden" asp-for="TotalPrice" />

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Trạng thái Đơn hàng hiện tại</label>
                    <div class="relative">
                        <select asp-for="Status" class="w-full pl-4 pr-10 py-4 bg-gray-50 border-2 border-gray-200 rounded-xl text-gray-900 font-bold focus:outline-none focus:ring-0 focus:border-blue-500 appearance-none cursor-pointer transition-colors text-lg">
                            <option value="Chờ xác nhận">⏳ Chờ xác nhận (Chưa chuyển khoản)</option>
                            <option value="Đã thanh toán">✅ Đã thanh toán (Sẵn sàng khởi hành)</option>
                            <option value="Hoàn tất">🏁 Hoàn tất (Đã đi tour về)</option>
                            <option value="Đã hủy">❌ Đã hủy đơn</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                            <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                    <p class="text-sm text-gray-500 mt-2 italic">Thay đổi trạng thái sẽ lập tức cập nhật màu sắc ngoài danh sách.</p>
                </div>

                <div class="pt-6 border-t border-gray-100">
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg shadow-blue-200 text-lg">
                        Lưu Trạng Thái Mới
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>