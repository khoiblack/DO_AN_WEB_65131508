@model BookingTourWeb.Models.Booking

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết Đơn hàng";
}

<div class="max-w-5xl mx-auto mt-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Chi tiết Đơn đặt Tour</h1>
            <p class="text-gray-500 mt-1">Mã đơn hàng: <span class="font-bold text-blue-600">#@Model.Id</span></p>
        </div>
        <a asp-action="Index" class="flex items-center gap-2 text-gray-600 hover:text-blue-600 font-medium transition-colors bg-white px-5 py-2.5 rounded-xl shadow-sm border border-gray-200 hover:border-blue-200 text-decoration-none">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Quay lại danh sách
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
            <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                Thông tin Khách hàng
            </h3>

            <div class="space-y-4">
                <div>
                    <p class="text-sm text-gray-500 mb-1">Họ và Tên</p>
                    <p class="font-bold text-gray-900 text-lg">@Model.CustomerName</p>
                </div>
                <div>
                    <p class="text-sm text-gray-500 mb-1">Số điện thoại liên hệ</p>
                    <p class="font-bold text-gray-900 text-lg flex items-center gap-2">
                        @Model.PhoneNumber
                        <a href="tel:@Model.PhoneNumber" class="text-blue-500 hover:text-blue-700 bg-blue-50 p-1.5 rounded-lg transition-colors" title="Gọi ngay">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" /></svg>
                        </a>
                    </p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
            <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Thông tin Chuyến đi
            </h3>

            <div class="space-y-4">
                <div>
                    <p class="text-sm text-gray-500 mb-1">Tour đăng ký</p>
                    <p class="font-bold text-gray-900">@(Model.Tour?.Name ?? "N/A")</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Ngày khởi hành</p>
                        <p class="font-bold text-gray-900">@Model.DepartureDate.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Số lượng khách</p>
                        <p class="font-bold text-gray-900">@Model.NumberOfGuests người</p>
                    </div>
                </div>

                <hr class="border-gray-100 my-4" />

                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Tổng tiền cần thu</p>
                        <p class="text-2xl font-black text-blue-600">@Model.TotalPrice.ToString("N0") VNĐ</p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm text-gray-500 mb-1">Trạng thái</p>
                        @{
                            string badgeBg = "bg-gray-100 border-gray-200 text-gray-700";
                            if (Model.Status == "Chờ xác nhận") badgeBg = "bg-amber-50 border-amber-200 text-amber-700";
                            else if (Model.Status == "Đã thanh toán" || Model.Status == "Hoàn tất") badgeBg = "bg-emerald-50 border-emerald-200 text-emerald-700";
                            else if (Model.Status == "Đã hủy") badgeBg = "bg-red-50 border-red-200 text-red-700";
                        }
                        <span class="inline-flex px-3 py-1 rounded-full text-xs font-bold border @badgeBg">
                            @Model.Status
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="flex gap-4">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-xl text-center transition-all shadow-lg shadow-blue-200 text-decoration-none">
            Cập nhật trạng thái đơn
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="flex-1 bg-red-50 hover:bg-red-100 text-red-600 font-bold py-3.5 px-4 rounded-xl text-center transition-all text-decoration-none">
            Xóa đơn hàng
        </a>
    </div>
</div>