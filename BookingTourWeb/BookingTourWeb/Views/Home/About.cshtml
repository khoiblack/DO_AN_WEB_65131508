@{
    ViewData["Title"] = "Về Chúng Tôi";
}

<div class="pt-24 pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Sứ mệnh của OceanWave</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
            Chúng tôi không chỉ bán những chuyến đi, chúng tôi mang đến những kỷ niệm vô giá dưới lòng đại dương và những phút giây thư giãn tuyệt đối bên bờ cát trắng.
        </p>
    </div>

    <div class="bg-blue-600 py-16 mb-20">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center text-white">
            <div>
                <p class="text-4xl font-bold mb-2">10+</p>
                <p class="text-blue-100">Năm kinh nghiệm</p>
            </div>
            <div>
                <p class="text-4xl font-bold mb-2">50K+</p>
                <p class="text-blue-100">Khách hàng hài lòng</p>
            </div>
            <div>
                <p class="text-4xl font-bold mb-2">100+</p>
                <p class="text-blue-100">Đối tác khách sạn</p>
            </div>
            <div>
                <p class="text-4xl font-bold mb-2">24/7</p>
                <p class="text-blue-100">Hỗ trợ khách hàng</p>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-12">
            <div class="text-center p-8 rounded-2xl bg-gray-50">
                <div class="text-4xl mb-4">🛡️</div>
                <h3 class="text-xl font-bold mb-4">An toàn là số 1</h3>
                <p class="text-gray-600">Đội ngũ cứu hộ và trang thiết bị lặn luôn được kiểm tra nghiêm ngặt hàng ngày.</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-gray-50">
                <div class="text-4xl mb-4">🌊</div>
                <h3 class="text-xl font-bold mb-4">Bảo vệ môi trường</h3>
                <p class="text-gray-600">Chúng tôi cam kết du lịch bền vững, không gây hại đến rạn san hô và sinh vật biển.</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-gray-50">
                <div class="text-4xl mb-4">⭐</div>
                <h3 class="text-xl font-bold mb-4">Dịch vụ tận tâm</h3>
                <p class="text-gray-600">Hướng dẫn viên của chúng tôi là những người địa phương am hiểu và nhiệt huyết nhất.</p>
            </div>
        </div>
    </div>
</div>